# Production Configuration
# HYBRID DEPLOYMENT: REST API on Vercel, WebSocket on Railway

# Vercel Backend REST API (will be updated after deployment)
VITE_API_BASE_URL=https://nextgent-backend.vercel.app/api/v1

# Railway WebSocket Service (will be updated after deployment)
VITE_WS_URL=wss://nextgent-ws.up.railway.app

# Instructions:
# 1. Deploy backend to Vercel -> Copy URL -> Update VITE_API_BASE_URL
# 2. Deploy websocket-service to Railway -> Copy URL -> Update VITE_WS_URL
# 3. Redeploy frontend to Vercel after updating both values
