{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "regions": [
    "fra1"
  ],
  "functions": {
    "api/analytics.py": {
      "runtime": "python3.9"
    },
    "api/auth_login.py": {
      "runtime": "python3.9"
    },
    "api/calendar_events.py": {
      "runtime": "python3.9"
    },
    "api/calls.py": {
      "runtime": "python3.9"
    },
    "api/dashboard_config.py": {
      "runtime": "python3.9"
    },
    "api/documents.py": {
      "runtime": "python3.9"
    },
    "api/helpdesk_chat.py": {
      "runtime": "python3.9"
    },
    "api/interactions.py": {
      "runtime": "python3.9"
    },
    "api/main.py": {
      "runtime": "python3.9"
    },
    "api/messages.py": {
      "runtime": "python3.9"
    },
    "api/satisfaction.py": {
      "runtime": "python3.9"
    },
    "api/tenants_me.py": {
      "runtime": "python3.9"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/auth/login",
      "destination": "/api/auth_login.py"
    },
    {
      "source": "/api/v1/tenants/me",
      "destination": "/api/tenants_me.py"
    },
    {
      "source": "/api/v1/calendar/events",
      "destination": "/api/calendar_events.py"
    },
    {
      "source": "/api/v1/documents",
      "destination": "/api/documents.py"
    },
    {
      "source": "/api/v1/messages",
      "destination": "/api/messages.py"
    },
    {
      "source": "/api/v1/calls",
      "destination": "/api/calls.py"
    },
    {
      "source": "/api/v1/helpdesk/chat",
      "destination": "/api/helpdesk_chat.py"
    },
    {
      "source": "/api/v1/analytics/:path*",
      "destination": "/api/analytics.py"
    },
    {
      "source": "/api/v1/satisfaction/:path*",
      "destination": "/api/satisfaction.py"
    },
    {
      "source": "/api/v1/interactions",
      "destination": "/api/interactions.py"
    },
    {
      "source": "/api/v1/dashboard/config",
      "destination": "/api/dashboard_config.py"
    },
    {
      "source": "/api/v1/health",
      "destination": "/api/analytics.py"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}