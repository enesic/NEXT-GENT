PROJECT_NAME=NextGent
API_V1_STR=/api/v1
SECRET_KEY=change_this_secret_key_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Encryption for PII (KVKK/GDPR Compliance)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# CORS Configuration
# Add your frontend URLs here (comma-separated for multiple origins)
# Local development example:
BACKEND_CORS_ORIGINS=http://localhost:5173
# Production example (Vercel):
# BACKEND_CORS_ORIGINS=https://your-domain.vercel.app,https://your-custom-domain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Local Development (Docker):
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nextgent
POSTGRES_PORT=5432

# Production (Vercel Postgres):
# POSTGRES_SERVER=your-postgres-host.vercel-storage.com
# POSTGRES_USER=default
# POSTGRES_PASSWORD=your-vercel-postgres-password
# POSTGRES_DB=verceldb
# POSTGRES_PORT=5432
# DATABASE_URL=postgres://default:password@host.vercel-storage.com:5432/verceldb

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Local Development (Docker):
REDIS_HOST=localhost
REDIS_PORT=6379

# Production (Vercel KV - Redis):
# REDIS_HOST=your-redis-host.vercel-storage.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_URL=redis://default:password@host.vercel-storage.com:6379

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
# Environment: local, staging, production
ENVIRONMENT=local
DEBUG=True

# For production deployment:
# ENVIRONMENT=production
# DEBUG=false